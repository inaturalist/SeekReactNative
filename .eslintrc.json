{
  "ignorePatterns": ["**/vendor/**"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "requireConfigFile": false,
    "babelOptions": {
      "presets": ["@babel/preset-react"]
    }
  },
  "extends": [
    "@react-native",
    "plugin:react-hooks/recommended"
  ],
  "plugins": [
    "@stylistic",
    "import",
    "lodash",
    "react-hooks"
  ],
  "rules": {
    "@stylistic/member-delimiter-style": 2,
    "@typescript-eslint/array-type": 2,
    "@typescript-eslint/consistent-type-imports": [
      2,
      {
        "fixStyle": "separate-type-imports"
      }
    ],
    "comma-dangle": [2, "always-multiline"],
    "import/consistent-type-specifier-style": [2, "prefer-top-level"],
    "import/no-extraneous-dependencies": [2, {}],
    "lodash/import-scope": 2,
    "prettier/prettier": 0,
    "quotes": [2, "double"],
    // React-Hooks Plugin
    // The following rules are made available via `eslint-plugin-react-hooks`
    "react-hooks/exhaustive-deps": 2,
    // React Compiler
    // These rules are specific to React Compiler.
    "react-hooks/static-components": 1,
    "react-hooks/set-state-in-effect": 1,
    "react-hooks/refs": 1,
    "react-hooks/preserve-manual-memoization": 1,
    "react-hooks/purity": 1,
    "react-hooks/immutability": 1,
    "space-in-parens": [2, "always"]
  },
  "settings": {
    "import/resolver": {
      "babel-module": { "allowExistingDirectories": true }
    }
  },
  "overrides": [
    {
      "files": ["tests/**/*", "__mocks__/**/*", "e2e/**/*"],
      "env": { "jest": true }
    },
    {
      "files": ["tests/**/*"],
      "plugins": ["testing-library"],
      "extends": ["plugin:testing-library/react"]
    }
  ]
}