{
  "ignorePatterns": ["**/vendor/**"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "requireConfigFile": false,
    "babelOptions": {
      "presets": ["@babel/preset-react"]
    }
  },
  "extends": [
    "@react-native",
    "plugin:@typescript-eslint/recommended",
    "plugin:react-hooks/recommended"
  ],
  "plugins": [
    "@stylistic",
    "@typescript-eslint",
    "import",
    "lodash",
    "react-hooks"
  ],
  "rules": {
    "@stylistic/member-delimiter-style": 2,
    "@typescript-eslint/array-type": [
      2,
      {
        "default": "array"
      }
    ],
    "@typescript-eslint/consistent-type-definitions": [2, "interface"],
    "@typescript-eslint/consistent-type-imports": [
      2,
      {
        "fixStyle": "separate-type-imports"
      }
    ],
    "@typescript-eslint/no-require-imports": [
      2,
      {
        "allow": ["\\.(png|webp)$"]
      }
    ],
    // TODO: I have disabled this for now because my current PR is only concerned about adding the
    // ruleset as iNat has it. Apparently, we have a lot of these errors but they all need dedicated
    // typing effort of whatever is an error here, i.e. no quick-fix.
    "@typescript-eslint/no-explicit-any": 1,
    "@typescript-eslint/no-unsafe-function-type": 1,
    "@typescript-eslint/no-unused-vars": [
      2,
      {
        "vars": "all",
        "args": "after-used",
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "ignoreRestSiblings": true,
        "caughtErrors": "all",
        // needed a special case for catch blocks that use _ to define an unused error
        "caughtErrorsIgnorePattern": "^_"
      }
    ],
    "comma-dangle": [2, "always-multiline"],
    "import/consistent-type-specifier-style": [2, "prefer-top-level"],
    "import/no-extraneous-dependencies": [2, {}],
    "lodash/import-scope": 2,
    "prettier/prettier": 0,
    "quotes": [2, "double"],
    // React-Hooks Plugin
    // The following rules are made available via `eslint-plugin-react-hooks`
    "react-hooks/exhaustive-deps": 2,
    // React Compiler
    // These rules are specific to React Compiler.
    "react-hooks/static-components": 1,
    "react-hooks/set-state-in-effect": 1,
    "react-hooks/refs": 1,
    "react-hooks/preserve-manual-memoization": 1,
    "react-hooks/purity": 1,
    "react-hooks/immutability": 1,
    "space-in-parens": [2, "always"]
  },
  "settings": {
    "import/resolver": {
      "babel-module": { "allowExistingDirectories": true }
    }
  },
  "overrides": [
    {
      "files": ["*.js", "*.jsx"],
      "rules": {
        "@typescript-eslint/consistent-type-definitions": "off",
        "@typescript-eslint/consistent-type-imports": "off",
        "@typescript-eslint/no-require-imports": "off",
        "@typescript-eslint/no-unsafe-function-type": "off",
        "@typescript-eslint/no-wrapper-object-types": "off",
        "@stylistic/member-delimiter-style": "off",
        "import/consistent-type-specifier-style": "off"
      }
    },
    {
      "files": ["**/__mocks__/**/*", "**/*mock*", "**/*.mock.*"],
      "rules": {
        "@typescript-eslint/no-require-imports": "off"
      }
    },
    {
      "files": ["tests/**/*", "__mocks__/**/*", "e2e/**/*"],
      "env": { "jest": true }
    },
    {
      "files": ["tests/**/*"],
      "plugins": ["testing-library"],
      "extends": ["plugin:testing-library/react"]
    }
  ]
}